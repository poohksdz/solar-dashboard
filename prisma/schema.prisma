generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
}

model House {
  id        String       @id @default(cuid())
  name      String
  config    Json?
  logs      SessionLog[]
}

model SessionLog {
  id              String   @id @default(cuid())
  timestamp       DateTime @default(now())
  simTime         Float
  simTimeLabel    String
  batteryLevel    Float
  totalSaved      Float
  weatherMode     String
  solarPower      Float
  homeConsumption Float
  gridImport      Float
  appliances      Json
  aiAutoMode      Boolean  @default(false)
  aiActionsCount  Int      @default(0)
  
  houseId         String
  house           House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
}
